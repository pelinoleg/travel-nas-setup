# =============================================================================
# /etc/travel-nas/power-mode.conf
# =============================================================================
# Конфиг для power-mode.sh — переключения профилей питания.
#
# HOME_SSIDS: список SSID домашнего/доверенного Wi-Fi. Когда Pi подключён к
# одному из них, режим = "home" (все Docker apps запущены, ondemand governor).
# В дороге (любой другой Wi-Fi или AP) режим = "field" (ondemand).
# При детекте под-вольтажа автоматически переключается в "emergency"
# (powersave + остановка тяжёлых apps).
#
# HEAVY_DOCKER_APPS: что останавливается в emergency. Имена должны совпадать
# с папками в /var/lib/casaos/apps/<name>/ или /opt/<name>/.
# =============================================================================

HOME_SSIDS=("MyHomeWiFi" "MyHomeWiFi_5GHz")

HEAVY_DOCKER_APPS=("ytarchiver" "photoview")
