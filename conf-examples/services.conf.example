# =============================================================================
# /etc/travel-nas/services.conf
# =============================================================================
# Список сервисов которые показываются в Dashboard → Menu → Services.
#
# Формат:
#   NAME=URL                        ← новый сервис (имя над URL, две строки)
#   >NAME=URL                       ← inline: "NAME: URL" одной строкой
#       заметка к сервису           ← строка с отступом = заметка (серым)
#       ещё одна заметка
#   # comment                       ← игнорируется
#                                   ← пустая строка игнорируется
#
# Подстановки в URL и заметках:
#   {host}  → travel-nas.local (mDNS — работает в локальной сети)
#   {ip}    → текущий IP (192.168.x.x или 10.41.x.x в AP режиме)
#
# На дашборде:
#   - NAME — синим (заголовок)
#   - URL  — белым (под именем — или после "NAME:" если >)
#   - заметки — мелким серым под URL
#
# После правок: нажми ⟳ Refresh на странице Services — подтянет без рестарта.
# =============================================================================

CasaOS=http://{host}
    Web-UI для Docker-приложений

Photoview=http://{host}:8000
    Login: admin / hammett
    Внутри контейнера: /t7/usb-imports

YT-Archiver=http://{host}:8081
    Self-hosted YouTube archive

# Компактный inline для коротких записей:
>Samba=smb://{host}/travel-nas
>SSH=ssh oleg@{host}
    pass: hammett
