# =============================================================================
# /etc/travel-nas/services.conf
# =============================================================================
# Список сервисов которые показываются в Dashboard → Menu → Services.
# Формат: NAME=URL (по одной строке). Подстановки в URL:
#   {host}  → travel-nas.local (mDNS — работает в локальной сети)
#   {ip}    → текущий IP (192.168.x.x или 10.41.x.x в AP режиме)
#
# Пустые строки и строки с # игнорируются.
# Если файл отсутствует, dashboard использует defaults эквивалентные ниже.
# =============================================================================

CasaOS=http://{host}
Photoview=http://{host}:8000
yt-archiver=http://{host}:8081
Samba=smb://{host}/travel-nas
SSH=ssh oleg@{host}
