# =============================================================================
# /etc/travel-nas/thermal-guard.conf
# =============================================================================
# Sustained-temperature защита. Если CPU temp держится высоко несколько
# минут — поэтапно зажимает / морозит / стопит docker-контейнер с
# максимальным CPU. Когда остынет — восстанавливает.
#
# Стадии (по возрастанию температуры):
#   throttle  — `docker update --cpus=$CPUS_THROTTLE` (мягкое зажатие)
#   pause     — `docker pause` (freeze cgroup'ом, состояние сохраняется)
#   stop      — `docker stop` (последний ресорт)
#
# Restore: temp ≤ COOLDOWN_TEMP подряд COOLDOWN_MIN минут → откатить всё.
# =============================================================================

# Главный switch. ENABLED=false полностью отключает (timer остаётся но скрипт молча выходит).
ENABLED=true

# warn  — только TG-алёрты, ничего не трогаем (рекомендуется для проверки настроек)
# auto  — реально эскалирует
MODE=warn

# Сколько минут подряд CPU temp должна быть выше порога чтобы реагировать
SUSTAINED_MIN=3

# Температурные пороги, °C
THROTTLE_TEMP=80
PAUSE_TEMP=82
STOP_TEMP=85

# Cooldown — когда отдавать обратно
COOLDOWN_TEMP=70
COOLDOWN_MIN=5

# Какие контейнеры НЕ трогать (regex по имени). По умолчанию:
#   *-db    — БД (mysql/postgres/mariadb) — pause/stop рискует данные
#   casaos  — управляющий слой Docker-апп, его падение каскадит остальное
EXCLUDE_REGEX=-db(-\d+)?$|^casaos

# Когда идёт nas-backup-runtime — не вмешиваемся
EXCLUDE_DURING_BACKUP=true

# Сколько CPU оставлять при throttle (0.5 = половина одного ядра)
CPUS_THROTTLE=0.5
